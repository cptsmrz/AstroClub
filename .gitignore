/coverage
*.lcov
.nyc_output

# ── Debug Logs ──
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ── Diagnostic Reports ──
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ── Runtime Data ──
pids
*.pid
*.seed
*.pid.lock

